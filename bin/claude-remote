#!/usr/bin/env bash
# claude-remote — spawn / list / kill Claude Code remote-control sessions.
#
# Subcommands:
#   claude-remote <path> [task]            (implicit spawn)
#   claude-remote spawn <path> [task]      (explicit)
#   claude-remote ls
#   claude-remote kill <name>
#   claude-remote kill --all

set -euo pipefail

EM=$'—'  # em-dash separator: cc—foo—task
URL_TIMEOUT_S=30
POLL_INTERVAL_S=0.5

usage() {
    cat <<EOF
Usage:
  claude-remote <path> [task]            Spawn a session (default action)
  claude-remote spawn <path> [task]      Same as above, explicit
  claude-remote ls                       List running cc— tmux sessions
  claude-remote kill <name>              Kill one tmux session
  claude-remote kill --all               Kill all cc— tmux sessions
  claude-remote refresh <name>           Re-issue /remote-control to get a fresh URL

Spawn output:
  SESSION: <tmux name>
  URL:     https://claude.ai/code/...
  ATTACH:  tmux attach -t <session>

Exit 1 if URL doesn't appear within ${URL_TIMEOUT_S}s.
EOF
}

die() { echo "claude-remote: $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# spawn
# ---------------------------------------------------------------------------
cmd_spawn() {
    [[ $# -lt 1 ]] && { usage; exit 2; }

    command -v tmux    >/dev/null || die "tmux not found"
    command -v claude  >/dev/null || die "claude not found in PATH"
    command -v python3 >/dev/null || die "python3 not found"
    [[ -f "$HOME/.claude.json" ]] || die "~/.claude.json not found — run 'claude' once to initialize"

    local raw_path="$1"
    local task="${2:-}"

    local abs_path
    abs_path=$(python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$raw_path")

    local is_new=0
    [[ -d "$abs_path" ]] || is_new=1
    (( is_new )) && mkdir -p "$abs_path"

    local base suffix session_name tmux_name
    base=$(basename "$abs_path")
    suffix="${task:-$(date +%m-%d_%H-%M)}"
    session_name="cc${EM}${base}${EM}${suffix}"

    tmux_name="$session_name"
    local i=2
    while tmux has-session -t "$tmux_name" 2>/dev/null; do
        tmux_name="${session_name}-${i}"
        ((i++))
    done

    # Pre-trust path in ~/.claude.json (atomic)
    python3 - "$abs_path" <<'PYEOF'
import json, os, sys, tempfile
path = sys.argv[1]
cfg_path = os.path.expanduser('~/.claude.json')
with open(cfg_path) as f:
    cfg = json.load(f)
projs = cfg.setdefault('projects', {})
entry = projs.setdefault(path, {})
entry['hasTrustDialogAccepted'] = True
defaults = {
    'allowedTools': [],
    'mcpContextUris': [],
    'mcpServers': {},
    'enabledMcpjsonServers': [],
    'disabledMcpjsonServers': [],
    'projectOnboardingSeenCount': 0,
    'hasClaudeMdExternalIncludesApproved': False,
    'hasClaudeMdExternalIncludesWarningShown': False,
    'exampleFiles': [],
}
for k, v in defaults.items():
    entry.setdefault(k, v)
fd, tmp = tempfile.mkstemp(prefix='.claude.json.', dir=os.path.dirname(cfg_path))
with os.fdopen(fd, 'w') as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, cfg_path)
PYEOF

    tmux new-session -d -s "$tmux_name" -c "$abs_path"

    local claude_name="${base}${EM}${suffix}"

    # Start interactive Claude with bypass; we'll enable Remote Control via slash.
    tmux send-keys -t "$tmux_name" "claude --dangerously-skip-permissions" Enter

    # Wait for the TUI to reach ready state. Handle the trust-prompt fallback
    # in case ~/.claude.json pre-trust didn't take effect.
    local trust_handled=0
    local ready=0
    local ready_iters
    ready_iters=$(awk 'BEGIN{print int(40/0.5)}')
    for _ in $(seq 1 "$ready_iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$tmux_name" -S -200 2>/dev/null || true)

        # Trust dialog still showing? Pick option 1.
        if (( !trust_handled )) && printf '%s' "$pane" | grep -qiE 'trust the files|yes, proceed'; then
            tmux send-keys -t "$tmux_name" '1' Enter
            trust_handled=1
            sleep 1
            continue
        fi

        # TUI bottom bar shows "bypass permissions on" once ready.
        if printf '%s' "$pane" | grep -q 'bypass permissions on'; then
            ready=1
            break
        fi

        sleep 0.5
    done

    if (( !ready )); then
        echo "claude-remote: claude TUI didn't reach ready state in 40s — check 'tmux attach -t $tmux_name'" >&2
        exit 1
    fi

    # Enable Remote Control via slash (carries chat history; cleanly recoverable).
    tmux send-keys -t "$tmux_name" "/remote-control '${claude_name}'" Enter

    local url=""
    local iters
    iters=$(awk -v t="$URL_TIMEOUT_S" -v s="$POLL_INTERVAL_S" 'BEGIN{print int(t/s)}')
    for _ in $(seq 1 "$iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$tmux_name" -S -200 2>/dev/null || true)
        url=$(printf '%s' "$pane" | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' | tail -1 || true)
        [[ -n "$url" ]] && break
        sleep "$POLL_INTERVAL_S"
    done

    printf 'SESSION: %s\n' "$tmux_name"
    if [[ -n "$url" ]]; then
        printf 'URL:     %s\n' "$url"
    else
        printf 'URL:     <timeout after %ss — check pane manually>\n' "$URL_TIMEOUT_S"
    fi
    printf "ATTACH:  tmux attach -t '%s'\n" "$tmux_name"

    [[ -n "$url" ]] || exit 1
}

# ---------------------------------------------------------------------------
# refresh — re-issue /remote-control inside an existing session to get a fresh URL
# ---------------------------------------------------------------------------
cmd_refresh() {
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "usage: claude-remote refresh <session>" >&2; exit 2; }
    tmux has-session -t "$name" 2>/dev/null || die "no such session: $name"

    # Capture the URL currently printed (if any) so we can detect the new one.
    local old_url
    old_url=$(tmux capture-pane -p -J -t "$name" -S -300 \
              | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' \
              | tail -1 || true)

    tmux send-keys -t "$name" '/remote-control' Enter

    local url=""
    local iters
    iters=$(awk -v t="$URL_TIMEOUT_S" -v s="$POLL_INTERVAL_S" 'BEGIN{print int(t/s)}')
    for _ in $(seq 1 "$iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$name" -S -300 2>/dev/null || true)
        local cand
        cand=$(printf '%s' "$pane" | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' | tail -1 || true)
        if [[ -n "$cand" && "$cand" != "$old_url" ]]; then
            url="$cand"
            break
        fi
        sleep "$POLL_INTERVAL_S"
    done

    printf 'SESSION: %s\n' "$name"
    if [[ -n "$url" ]]; then
        printf 'URL:     %s\n' "$url"
    else
        printf 'URL:     <no new URL within %ss — old still: %s>\n' "$URL_TIMEOUT_S" "${old_url:-none}"
    fi
    [[ -n "$url" ]] || exit 1
}

# ---------------------------------------------------------------------------
# ls
# ---------------------------------------------------------------------------
cmd_list() {
    local rows
    rows=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep '^cc—' || true)
    if [[ -z "$rows" ]]; then
        echo "(no cc— sessions running)"
        return
    fi
    printf '%-50s  %s\n' "SESSION" "PATH"
    printf '%s\n' "$rows" | awk -F'|' '{ printf "%-50s  %s\n", $1, $2 }'
}

# ---------------------------------------------------------------------------
# kill <name> | kill --all
# ---------------------------------------------------------------------------
cmd_kill() {
    case "${1:-}" in
        "")
            echo "claude-remote kill: missing <name> or --all" >&2
            exit 2
            ;;
        --all)
            local names
            names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^cc—' || true)
            if [[ -z "$names" ]]; then
                echo "(no cc— sessions to kill)"
                return
            fi
            while IFS= read -r n; do
                tmux kill-session -t "$n" && echo "killed: $n"
            done <<< "$names"
            ;;
        *)
            local name="$1"
            if tmux has-session -t "$name" 2>/dev/null; then
                tmux kill-session -t "$name"
                echo "killed: $name"
            else
                echo "no such session: $name" >&2
                exit 1
            fi
            ;;
    esac
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
    -h|--help) usage ;;
    "")        usage; exit 2 ;;
    ls)        cmd_list ;;
    kill)      shift; cmd_kill "$@" ;;
    spawn)     shift; cmd_spawn "$@" ;;
    refresh)   shift; cmd_refresh "$@" ;;
    *)         cmd_spawn "$@" ;;
esac
