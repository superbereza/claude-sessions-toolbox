#!/usr/bin/env bash
# claude-remote — spawn a detached Claude Code remote-control session in tmux
#
# Creates or uses <path>, pre-trusts it for Claude Code (no interactive trust
# dialog), starts a tmux session running 'claude remote-control', and prints
# the session URL captured from the pane.

set -euo pipefail

EM=$'—'  # em-dash separator: cc—foo—task
URL_TIMEOUT_S=30
POLL_INTERVAL_S=0.5

usage() {
    cat <<EOF
Usage: claude-remote <path> [task-name]

Args:
  <path>       Folder to run Claude in. Created if missing.
  [task-name]  Optional name for tmux/claude session.
               Falls back to MM-DD_HH-MM timestamp.

Examples:
  claude-remote ~/dev/myproject
  claude-remote ~/dev/newproject debug-auth

Output:
  SESSION: <tmux session name>
  URL:     <https://claude.ai/code/...>
  ATTACH:  tmux attach -t <session>
EOF
}

die() { echo "claude-remote: $*" >&2; exit 1; }

# --- pre-flight ---
[[ $# -lt 1 || ${1:-} == -h || ${1:-} == --help ]] && { usage; exit 0; }
command -v tmux    >/dev/null || die "tmux not found"
command -v claude  >/dev/null || die "claude not found in PATH"
command -v python3 >/dev/null || die "python3 not found"
[[ -f "$HOME/.claude.json" ]] || die "~/.claude.json not found — run 'claude' once to initialize"

raw_path="$1"
task="${2:-}"

# resolve absolute path with ~ expansion
abs_path=$(python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$raw_path")

is_new=0
[[ -d "$abs_path" ]] || is_new=1

(( is_new )) && mkdir -p "$abs_path"

base=$(basename "$abs_path")
suffix="${task:-$(date +%m-%d_%H-%M)}"
session_name="cc${EM}${base}${EM}${suffix}"

# Resolve tmux name collision
tmux_name="$session_name"
i=2
while tmux has-session -t "$tmux_name" 2>/dev/null; do
    tmux_name="${session_name}-${i}"
    ((i++))
done

# --- pre-trust the path in ~/.claude.json (atomic) ---
python3 - "$abs_path" <<'PYEOF'
import json, os, sys, tempfile
path = sys.argv[1]
cfg_path = os.path.expanduser('~/.claude.json')
with open(cfg_path) as f:
    cfg = json.load(f)
projs = cfg.setdefault('projects', {})
entry = projs.setdefault(path, {})
entry['hasTrustDialogAccepted'] = True
defaults = {
    'allowedTools': [],
    'mcpContextUris': [],
    'mcpServers': {},
    'enabledMcpjsonServers': [],
    'disabledMcpjsonServers': [],
    'projectOnboardingSeenCount': 0,
    'hasClaudeMdExternalIncludesApproved': False,
    'hasClaudeMdExternalIncludesWarningShown': False,
    'exampleFiles': [],
}
for k, v in defaults.items():
    entry.setdefault(k, v)
fd, tmp = tempfile.mkstemp(prefix='.claude.json.', dir=os.path.dirname(cfg_path))
with os.fdopen(fd, 'w') as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, cfg_path)
PYEOF

# --- start tmux session, wide pane so URL fits on one line ---
tmux new-session -d -s "$tmux_name" -x 220 -y 50 -c "$abs_path"

claude_name="${base}${EM}${suffix}"
launch_cmd="claude remote-control --name '${claude_name}' --permission-mode bypassPermissions"
tmux send-keys -t "$tmux_name" "$launch_cmd" Enter

# --- poll capture-pane for the session URL ---
url=""
iters=$(awk -v t="$URL_TIMEOUT_S" -v s="$POLL_INTERVAL_S" 'BEGIN{print int(t/s)}')
for _ in $(seq 1 "$iters"); do
    pane=$(tmux capture-pane -p -t "$tmux_name" -S -200 2>/dev/null || true)
    url=$(printf '%s' "$pane" | grep -oE 'https://claude\.ai/code/[A-Za-z0-9._~:/?#@!$&+=%-]+' | head -1 || true)
    [[ -n "$url" ]] && break
    sleep "$POLL_INTERVAL_S"
done

# --- output ---
printf 'SESSION: %s\n' "$tmux_name"
if [[ -n "$url" ]]; then
    printf 'URL:     %s\n' "$url"
else
    printf 'URL:     <timeout after %ss — check pane manually>\n' "$URL_TIMEOUT_S"
fi
printf "ATTACH:  tmux attach -t '%s'\n" "$tmux_name"

[[ -z "$url" ]] && exit 1 || exit 0
