#!/usr/bin/env bash
# claude-remote — spawn / list / kill Claude Code remote-control sessions.
#
# Subcommands:
#   claude-remote <path> [name] [--url]    (implicit spawn)
#   claude-remote spawn <path> [name] [--url]   (explicit)
#   claude-remote ls
#   claude-remote kill <session>
#   claude-remote kill --all

set -euo pipefail

EM=$'—'  # em-dash separator: cc—foo—task
URL_TIMEOUT_S=45
POLL_INTERVAL_S=0.5

# Resolve this script's repo root (portable, follows symlinks) to find VERSION.
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
    _d=$(cd -P "$(dirname "$_src")" && pwd); _src=$(readlink "$_src")
    [[ "$_src" != /* ]] && _src="$_d/$_src"
done
SCRIPT_ROOT=$(cd -P "$(dirname "$_src")/.." && pwd)

cmd_version() {
    local v="unknown"
    [[ -f "$SCRIPT_ROOT/VERSION" ]] && v=$(cat "$SCRIPT_ROOT/VERSION")
    echo "claude-remote $v"
}

usage() {
    cat <<EOF
Usage:
  claude-remote <path> [name] [--url] [--resume <uuid>] [--model <m>]
                                              Spawn a session (default action)
  claude-remote spawn <path> [name] [--url] [--resume <uuid>] [--model <m>]
                                              Same as above, explicit
  claude-remote ls                            List running cc— tmux sessions
  claude-remote kill <session>                Kill one tmux session
  claude-remote kill --all                    Kill all cc— tmux sessions
  claude-remote refresh <session>             Re-issue /remote-control for a fresh URL

Args:
  <path>   Project folder (created if it doesn't exist).
  [name]   Session name = remote-control chat title. Default: the folder name.
           Pass it in full (e.g. "mac-mini/ai-auth-lib") for a "device/" prefix —
           nothing is prepended automatically.

Flags:
  --url, -u           Also print the claude.ai/code URL. Default: status only.
  --resume <uuid>     Resume an existing session by UUID in the new tmux pane
  -r <uuid>           (instead of starting a fresh conversation).
  --model <m>         Launch on a specific model (alias: opus/sonnet/fable, or a
  -m <m>              full id like claude-opus-4-8). Default: claude's own default.

Spawn output (default):
  SESSION: <tmux name>
  STATUS:  remote-control active
  ATTACH:  tmux attach -t <session>

With --url the STATUS line becomes:
  URL:     https://claude.ai/code/...

Exit 1 only if Remote Control doesn't activate within ${URL_TIMEOUT_S}s
  (a missing --url link while RC is active is NOT a failure).
EOF
}

die() { echo "claude-remote: $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# spawn
# ---------------------------------------------------------------------------
cmd_spawn() {
    # Flags may appear anywhere among the args. Default: status only, no URL.
    # Pass --url (-u) to also print the claude.ai/code URL.
    # Pass --resume <uuid> to resume an existing session by its UUID instead
    # of starting a new conversation in the pane.
    # Pass --model <alias> to launch on a specific model (alias like opus/sonnet/
    # fable, or a full id like claude-opus-4-8). Default: claude's own default.
    local show_url=0
    local resume_uuid=""
    local model=""
    local -a pos=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url|-u)   show_url=1 ;;
            --resume|-r)
                [[ -n "${2:-}" ]] || die "--resume requires a session UUID"
                resume_uuid="$2"
                shift
                ;;
            --model|-m)
                [[ -n "${2:-}" ]] || die "--model requires a model alias or id"
                model="$2"
                shift
                ;;
            --)         shift; while [[ $# -gt 0 ]]; do pos+=("$1"); shift; done; break ;;
            *)          pos+=("$1") ;;
        esac
        shift
    done

    local raw_path="${pos[0]:-}"
    local name="${pos[1]:-}"
    [[ -z "$raw_path" ]] && { usage; exit 2; }

    command -v tmux    >/dev/null || die "tmux not found"
    command -v claude  >/dev/null || die "claude not found in PATH"
    command -v python3 >/dev/null || die "python3 not found"
    [[ -f "$HOME/.claude.json" ]] || die "~/.claude.json not found — run 'claude' once to initialize"

    local abs_path
    abs_path=$(python3 -c 'import os,sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$raw_path")

    local is_new=0
    [[ -d "$abs_path" ]] || is_new=1
    (( is_new )) && mkdir -p "$abs_path"

    local base session_name tmux_name final_name
    base=$(basename "$abs_path")
    # Session name = remote-control chat title. Defaults to the folder name
    # (clean, no timestamp). Nothing is prepended automatically — pass the name
    # in full (e.g. "mac-mini/ai-auth-lib") if you want a "device/" prefix.
    [[ -z "$name" ]] && name="$base"

    # Pick a free name. The collision check must be EXACT: `tmux has-session -t X`
    # matches on an unambiguous PREFIX, so spawning "dev" when a "dev-helper"
    # session exists would falsely "collide" and bump to "dev-2". Compare full
    # session names with `grep -xF` instead (handles the em-dash and slashes).
    # On a REAL collision, number BOTH the tmux session AND the chat title, so the
    # two chats are distinguishable on the device (not two identically-named ones).
    final_name="$name"
    local i=2
    while tmux list-sessions -F '#{session_name}' 2>/dev/null \
            | grep -qxF -- "cc${EM}${final_name}"; do
        final_name="${name}-${i}"
        ((i++))
    done
    session_name="cc${EM}${final_name}"
    tmux_name="$session_name"

    # Pre-accept bypass-permissions mode so claude won't pause on the
    # one-time confirmation dialog on its first --dangerously-skip-permissions run.
    # Idempotent: only writes the flag, preserves any other settings.
    python3 - <<'PYEOF'
import json, os
path = os.path.expanduser('~/.claude/settings.json')
os.makedirs(os.path.dirname(path), exist_ok=True)
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        data = {}
if data.get('bypassPermissionsModeAccepted') is not True:
    data['bypassPermissionsModeAccepted'] = True
    with open(path, 'w') as f:
        json.dump(data, f, indent=2)
PYEOF

    # Pre-trust path in ~/.claude.json (atomic)
    python3 - "$abs_path" <<'PYEOF'
import json, os, sys, tempfile
path = sys.argv[1]
cfg_path = os.path.expanduser('~/.claude.json')
with open(cfg_path) as f:
    cfg = json.load(f)
projs = cfg.setdefault('projects', {})
entry = projs.setdefault(path, {})
entry['hasTrustDialogAccepted'] = True
defaults = {
    'allowedTools': [],
    'mcpContextUris': [],
    'mcpServers': {},
    'enabledMcpjsonServers': [],
    'disabledMcpjsonServers': [],
    'projectOnboardingSeenCount': 0,
    'hasClaudeMdExternalIncludesApproved': False,
    'hasClaudeMdExternalIncludesWarningShown': False,
    'exampleFiles': [],
}
for k, v in defaults.items():
    entry.setdefault(k, v)
fd, tmp = tempfile.mkstemp(prefix='.claude.json.', dir=os.path.dirname(cfg_path))
with os.fdopen(fd, 'w') as f:
    json.dump(cfg, f, indent=2)
os.replace(tmp, cfg_path)
PYEOF

    tmux new-session -d -s "$tmux_name" -c "$abs_path"

    # Chat title follows the (possibly numbered) final name, so a collision-bumped
    # session shows as "name-2" on the device instead of a duplicate "name".
    local claude_name="$final_name"

    # Build the claude launch command. With --resume <uuid>, claude reopens that
    # specific session in this pane instead of starting a fresh conversation.
    local claude_cmd="claude --dangerously-skip-permissions"
    if [[ -n "$resume_uuid" ]]; then
        claude_cmd+=" --resume $resume_uuid"
    fi
    if [[ -n "$model" ]]; then
        claude_cmd+=" --model $model"
    fi

    # Start interactive Claude; we'll enable Remote Control via slash.
    tmux send-keys -t "$tmux_name" "$claude_cmd" Enter

    # Wait for the TUI to reach ready state (bottom bar shows "bypass permissions on").
    # Trust dialog is skipped because we pre-wrote hasTrustDialogAccepted above.
    local ready=0
    local ready_iters
    ready_iters=$(awk 'BEGIN{print int(40/0.5)}')
    for _ in $(seq 1 "$ready_iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$tmux_name" -S -200 2>/dev/null || true)
        if printf '%s' "$pane" | grep -q 'bypass permissions on'; then
            ready=1
            break
        fi
        sleep 0.5
    done

    if (( !ready )); then
        echo "claude-remote: claude TUI didn't reach ready state in 40s — check 'tmux attach -t $tmux_name'" >&2
        exit 1
    fi

    # Enable Remote Control via slash (carries chat history; cleanly recoverable).
    # No quotes around the name — slash command takes the rest of the line as the title verbatim,
    # so quotes would end up in the displayed name.
    tmux send-keys -t "$tmux_name" "/remote-control ${claude_name}" Enter

    local url="" rc_active=0 confirmed_rc=0 iters
    iters=$(awk -v t="$URL_TIMEOUT_S" -v s="$POLL_INTERVAL_S" 'BEGIN{print int(t/s)}')
    for _ in $(seq 1 "$iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$tmux_name" -S -200 2>/dev/null || true)
        # Auto-confirm the "Enable Remote Control" prompt (default option 1)
        # that appears the first time /remote-control runs in a session.
        if (( !confirmed_rc )) && printf '%s' "$pane" | grep -q 'Enable Remote Control'; then
            tmux send-keys -t "$tmux_name" Enter
            confirmed_rc=1
            sleep 0.5
            continue
        fi
        # Primary success signal is the persistent "Remote Control active" status
        # bar — NOT the URL. The URL is only needed for --url, and it can appear
        # late or scroll out of the captured window, which used to cause a false
        # "not detected" + exit 1 even though RC was up.
        printf '%s' "$pane" | grep -q 'Remote Control active' && rc_active=1
        if [[ -z "$url" ]]; then
            url=$(printf '%s' "$pane" | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' | tail -1 || true)
        fi
        # Done once RC is active (and, if --url was asked, once we also have the URL).
        if (( rc_active )) && { (( !show_url )) || [[ -n "$url" ]]; }; then break; fi
        sleep "$POLL_INTERVAL_S"
    done

    printf 'SESSION: %s\n' "$tmux_name"
    if (( show_url )); then
        if [[ -n "$url" ]]; then
            printf 'URL:     %s\n' "$url"
        elif (( rc_active )); then
            printf 'URL:     <RC active; link not captured — run: claude-remote refresh %q>\n' "$tmux_name"
        else
            printf 'URL:     <remote-control did not come up within %ss — check pane>\n' "$URL_TIMEOUT_S"
        fi
    else
        if (( rc_active )); then
            printf 'STATUS:  remote-control active\n'
        else
            printf 'STATUS:  remote-control did NOT activate within %ss — check pane\n' "$URL_TIMEOUT_S"
        fi
    fi
    printf "ATTACH:  tmux attach -t '%s'\n" "$tmux_name"

    # Fail only if Remote Control genuinely never activated (not merely "no URL").
    if (( !rc_active )); then
        echo "claude-remote: --- last 30 lines of pane '$tmux_name' ---" >&2
        tmux capture-pane -p -J -t "$tmux_name" -S -30 2>/dev/null >&2 || true
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# refresh — re-issue /remote-control inside an existing session to get a fresh URL
# ---------------------------------------------------------------------------
cmd_refresh() {
    local name="${1:-}"
    [[ -z "$name" ]] && { echo "usage: claude-remote refresh <session>" >&2; exit 2; }
    tmux has-session -t "$name" 2>/dev/null || die "no such session: $name"

    # Capture the URL currently printed (if any) so we can detect the new one.
    local old_url
    old_url=$(tmux capture-pane -p -J -t "$name" -S -300 \
              | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' \
              | tail -1 || true)

    tmux send-keys -t "$name" '/remote-control' Enter

    local url=""
    local iters
    iters=$(awk -v t="$URL_TIMEOUT_S" -v s="$POLL_INTERVAL_S" 'BEGIN{print int(t/s)}')
    for _ in $(seq 1 "$iters"); do
        local pane
        pane=$(tmux capture-pane -p -J -t "$name" -S -300 2>/dev/null || true)
        local cand
        cand=$(printf '%s' "$pane" | grep -oE 'https://claude\.ai/code[/?][A-Za-z0-9._~:/?#@!$&+=%-]+' | tail -1 || true)
        if [[ -n "$cand" && "$cand" != "$old_url" ]]; then
            url="$cand"
            break
        fi
        sleep "$POLL_INTERVAL_S"
    done

    printf 'SESSION: %s\n' "$name"
    if [[ -n "$url" ]]; then
        printf 'URL:     %s\n' "$url"
    else
        printf 'URL:     <no new URL within %ss — old still: %s>\n' "$URL_TIMEOUT_S" "${old_url:-none}"
    fi
    [[ -n "$url" ]] || exit 1
}

# ---------------------------------------------------------------------------
# ls
# ---------------------------------------------------------------------------
cmd_list() {
    local rows
    rows=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep '^cc—' || true)
    if [[ -z "$rows" ]]; then
        echo "(no cc— sessions running)"
        return
    fi
    printf '%-50s  %s\n' "SESSION" "PATH"
    printf '%s\n' "$rows" | awk -F'|' '{ printf "%-50s  %s\n", $1, $2 }'
}

# ---------------------------------------------------------------------------
# kill <name> | kill --all
# ---------------------------------------------------------------------------
cmd_kill() {
    case "${1:-}" in
        "")
            echo "claude-remote kill: missing <name> or --all" >&2
            exit 2
            ;;
        --all)
            local names
            names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^cc—' || true)
            if [[ -z "$names" ]]; then
                echo "(no cc— sessions to kill)"
                return
            fi
            while IFS= read -r n; do
                tmux kill-session -t "$n" && echo "killed: $n"
            done <<< "$names"
            ;;
        *)
            local name="$1"
            if tmux has-session -t "$name" 2>/dev/null; then
                tmux kill-session -t "$name"
                echo "killed: $name"
            else
                echo "no such session: $name" >&2
                exit 1
            fi
            ;;
    esac
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
    -h|--help) usage ;;
    -V|--version) cmd_version ;;
    "")        usage; exit 2 ;;
    ls)        cmd_list ;;
    kill)      shift; cmd_kill "$@" ;;
    spawn)     shift; cmd_spawn "$@" ;;
    refresh)   shift; cmd_refresh "$@" ;;
    *)         cmd_spawn "$@" ;;
esac
