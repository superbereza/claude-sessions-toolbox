#!/usr/bin/env bash
# claude-remote-kill — list or kill cc— tmux sessions spawned by claude-remote.
set -euo pipefail

usage() {
    cat <<EOF
Usage: claude-remote-kill [name | --all]

  (no args)    List all cc— tmux sessions (name + cwd)
  <name>       Kill the specified tmux session
  --all        Kill all cc— tmux sessions
EOF
}

list_sessions() {
    local rows
    rows=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep '^cc—' || true)
    if [[ -z "$rows" ]]; then
        echo "(no cc— sessions running)"
        return
    fi
    printf '%-50s  %s\n' "SESSION" "PATH"
    printf '%s\n' "$rows" | awk -F'|' '{ printf "%-50s  %s\n", $1, $2 }'
}

case "${1:-}" in
    -h|--help) usage ;;
    "") list_sessions ;;
    --all)
        names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^cc—' || true)
        if [[ -z "$names" ]]; then
            echo "(no cc— sessions to kill)"
            exit 0
        fi
        while IFS= read -r n; do
            tmux kill-session -t "$n" && echo "killed: $n"
        done <<< "$names"
        ;;
    -*)
        echo "unknown flag: $1" >&2; usage; exit 2 ;;
    *)
        name="$1"
        if tmux has-session -t "$name" 2>/dev/null; then
            tmux kill-session -t "$name"
            echo "killed: $name"
        else
            echo "no such session: $name" >&2
            exit 1
        fi
        ;;
esac
